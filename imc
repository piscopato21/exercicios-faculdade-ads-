print("=====IMC====")
altura = float(input("Digite a sua altura: "))
peso = float(input("Digite o seu peso: "))
imc = peso / (altura**2)
if imc <= 18.5:
    print(f"Seu IMC é {imc:.2f}.\nVocê está abaixo do peso normal.")
elif 18.6 <= imc <= 25:
    print(f"Seu IMC é {imc:.2f}.\nO seu peso está na faixa de normalidade.")
elif 26 <= imc <= 30:
    print(f"Seu IMC é {imc:.2f}.\nVocê está acima do seu peso normal.")
else:
    print(f"Seu IMC é {imc:.2f}.\nVocê precisa perder uns quilinhos.")
    
